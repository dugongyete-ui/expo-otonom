# ─── G4F AI Configuration ───────────────────────────────────────────────
# Required: API key from https://g4f.dev/
G4F_API_KEY=your-g4f-api-key-here

# Chat model (used for regular chat mode)
G4F_CHAT_MODEL=auto

# Agent model (used for autonomous agent mode with tool calling)
G4F_AGENT_MODEL=auto

# ─── Database Configuration ────────────────────────────────────────────────────
# MongoDB Atlas URI (for session persistence)
# The database name in the URI is ignored — MONGO_DB_NAME below takes precedence
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/manus?retryWrites=true&w=majority

# MongoDB database name used by ALL layers (TypeScript + Python). Default: manus
MONGO_DB_NAME=manus

# Redis (for session caching)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=16364
REDIS_PASSWORD=your-redis-password-here

# Session TTL in hours (default: 24)
SESSION_TTL_HOURS=24

# ─── Authentication ────────────────────────────────────────────────────────────
# Auth provider: none (auto-login), password (MongoDB users), local (env vars)
AUTH_PROVIDER=none

# JWT secret — WAJIB jika AUTH_PROVIDER=password atau local (min 32 karakter)
# Generate: openssl rand -hex 32
JWT_SECRET=

# Local auth credentials (hanya untuk AUTH_PROVIDER=local)
LOCAL_USER_EMAIL=
LOCAL_USER_PASSWORD=

# ─── Search Providers ──────────────────────────────────────────────────────────
# Search provider utama: bing_web|bing|google|tavily|duckduckgo
# Default: bing_web (scraper tanpa API key) atau bing jika BING_SEARCH_API_KEY ada
SEARCH_PROVIDER=bing_web

# Bing Web Search API key (opsional — untuk SEARCH_PROVIDER=bing)
# Get from: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SEARCH_API_KEY=

# Tavily Search API key (opsional — untuk SEARCH_PROVIDER=tavily)
# Get from: https://app.tavily.com/
TAVILY_API_KEY=

# Google Custom Search (opsional — untuk SEARCH_PROVIDER=google)
# Get from: https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ─── E2B Sandbox ───────────────────────────────────────────────────────────────
# E2B API key (required for sandbox execution — no local fallback)
# Get from: https://e2b.dev/
E2B_API_KEY=your-e2b-api-key-here

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Log level: DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# ─── App Domain ───────────────────────────────────────────────────────────────
# Set this to your deployment domain (e.g., dzeck-ai.replit.app)
APP_DOMAIN=

# Expo Public Domain (used by the mobile app to connect to the API)
EXPO_PUBLIC_DOMAIN=

# Expo Public API Port (used by mobile app when EXPO_PUBLIC_DOMAIN is not set)
EXPO_PUBLIC_API_PORT=5000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Additional allowed origins (comma-separated)
# Example: https://myapp.com,https://admin.myapp.com
# Note: localhost, Expo Go (exp://), and Replit dev tunnels are always allowed in dev mode
CORS_ORIGINS=

# ─── Email (optional) ─────────────────────────────────────────────────────────
# SMTP server configuration — required to use the send_email agent tool
# If not set, the email tool will return a clear error message instead of failing silently
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# ─── Agent Concurrency ────────────────────────────────────────────────────────
# Max concurrent agent runs per user (default: 1)
MAX_CONCURRENT_AGENTS_PER_USER=1

# ─── MCP Server (optional) ────────────────────────────────────────────────────
# Path ke file mcp.json untuk konfigurasi MCP tools
MCP_CONFIG_PATH=
